# ============================================
# FlashScan - Root .gitignore
# ============================================

# Dependencies
node_modules/
jspm_packages/

# Build outputs
dist/
build/
.next/
out/

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.test
.env.production
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Cache and temporary files
.eslintcache
.npm/
.yarn/
coverage/
.nyc_output/
*.tsbuildinfo

# Lint output files
lint.json
lint.txt
