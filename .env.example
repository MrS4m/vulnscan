# ============================================
# FlashScan - Environment Template
# Copie este arquivo para ".env" e preencha
# ============================================

# Supabase Configuration
# Essas credenciais podem ser obtidas no painel do Supabase (Project Settings > API)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-chave-secreta-service-role-aqui

# Configurações do Backend (API)
PORT=3000
NODE_ENV=production
CORS_ORIGIN=*

# Caminho para o Nmap
# Para deploy com DOCKER ou LINUX deixe apenas 'nmap'
# Para ambiente de DEV WINDOWS deixe 'C:\Program Files (x86)\Nmap\nmap.exe'
NMAP_PATH=nmap

# Configurações do Frontend
# Ajuste o localhost se for rodar em uma VPS na internet (coloque o IP ou Dominio)
VITE_API_URL=http://localhost:3000/api/v1
